#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG="/usr/bin/HomeNet-Sentinel"
CONF="homenet-sentinel"

TARGETS=""

build_target_env() {
	local cfg="$1"
	local name ip safe_name

	config_get name "$cfg" name
	config_get ip "$cfg" ip

	[ -n "$name" ] || return 0
	[ -n "$ip" ] || return 0

	safe_name="$(printf '%s' "$name" | tr '|;' '__')"

	if [ -n "$TARGETS" ]; then
		TARGETS="${TARGETS};${safe_name}|${ip}"
	else
		TARGETS="${safe_name}|${ip}"
	fi
}

start_service() {
	local enabled broker_host broker_port username password
	local wan_interface wan_status_interface wan_ipv6_status_interface
	local wan_rate_refresh_interval_seconds

	[ -x "$PROG" ] || return 1

	config_load "$CONF"
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get broker_host main broker_host
	config_get broker_port main broker_port
	config_get username main username
	config_get password main password
	config_get wan_interface main wan_interface "pppoe-wan"
	config_get wan_status_interface main wan_status_interface "wan"
	config_get wan_ipv6_status_interface main wan_ipv6_status_interface "wan_6"
	config_get wan_rate_refresh_interval_seconds main wan_rate_refresh_interval_seconds "3"

	[ -n "$broker_host" ] || {
		logger -t homenet-sentinel "broker_host is empty"
		return 1
	}

	[ -n "$broker_port" ] || {
		logger -t homenet-sentinel "broker_port is empty"
		return 1
	}

	TARGETS=""
	config_foreach build_target_env target

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param env \
		"HNS_BROKER_HOST=$broker_host" \
		"HNS_BROKER_PORT=$broker_port" \
		"HNS_MQTT_USERNAME=$username" \
		"HNS_MQTT_PASSWORD=$password" \
		"HNS_TARGETS=$TARGETS" \
		"HNS_WAN_INTERFACE=$wan_interface" \
		"HNS_WAN_STATUS_INTERFACE=$wan_status_interface" \
		"HNS_WAN_IPV6_STATUS_INTERFACE=$wan_ipv6_status_interface" \
		"HNS_WAN_RATE_REFRESH_INTERVAL_SECONDS=$wan_rate_refresh_interval_seconds"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 5 5 0
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "$CONF"
}
